# Copy to .env and fill in real values. Never commit .env
#   cp .env.example .env

# Required for live LLM calls (https://console.x.ai)
XAI_API_KEY=

# Optional overrides
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4.5

# Optional: encrypt topic strings in --audit-log files (Fernet).
# Requires: pip install 'dagztagz-hypothesis-engine[audit]'  (or pip install -e '.[audit]')
# If this is set without that install, the CLI exits with install instructions.
# Use a long random passphrase. Never commit the real value.
# AUDIT_LOG_KEY=
